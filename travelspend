}

// ══════════════════════════════════════════════════
// INIT — tout passe par addEventListener, jamais d'onclick= dans le HTML de login
// ══════════════════════════════════════════════════
async function init(){
  // Thème
  applyTheme(localStorage.getItem('ts_theme')||'dark');

  // Boutons thème
  document.getElementById('btnDark')?.addEventListener('click', ()=>applyTheme('dark'));
  document.getElementById('btnLight')?.addEventListener('click', ()=>applyTheme('light'));

  // Boutons paramètres (event listeners au lieu de onclick dans le HTML)
  document.getElementById('logoutBtn')?.addEventListener('click', logout);
  document.getElementById('copyBinBtn')?.addEventListener('click', ()=>{
    const id=currentUser?.binId||'—';
    navigator.clipboard?.writeText(id).then(()=>toast('📋 Bin ID copié')).catch(()=>toast(id));
  });
  document.getElementById('forceSyncBtn')?.addEventListener('click', forceSync);
  document.getElementById('exportXlsBtn')?.addEventListener('click', exportExcel);
  document.getElementById('exportJsonBtn')?.addEventListener('click', exportData);
  document.getElementById('reloadCloudBtn')?.addEventListener('click', cloudLoad);
  document.getElementById('resetBtn')?.addEventListener('click', resetData);
  document.getElementById('userBadge')?.addEventListener('click', logout);

  // LOGIN — code digits
  setupCodeInputs('cd', ()=>{ /* auto-submit on last digit */ });
  setupCodeInputs('nc', ()=>{});

  // Bouton Entrer
  document.getElementById('loginBtn')?.addEventListener('click', async ()=>{
    const code=getCode('cd');
    document.getElementById('loginErr').textContent='';
    if(code.length!==4){ document.getElementById('loginErr').textContent='Code incomplet'; return; }
    if(!REGISTRY[code]){ document.getElementById('loginErr').textContent='❌ Code inconnu — créez un profil'; return; }
    await doLogin(code);
  });

  // Toggle formulaire nouveau profil
  document.getElementById('newUserToggle')?.addEventListener('click', ()=>{
    const f=document.getElementById('newUserForm');
    f.classList.toggle('open');
    if(f.classList.contains('open')) document.getElementById('nuName')?.focus();
  });

  // Bouton Créer profil
  document.getElementById('createBtn')?.addEventListener('click', async ()=>{
    const name=document.getElementById('nuName')?.value.trim();
    const emoji=document.getElementById('nuEmoji')?.value.trim()||'😎';
    const code=getCode('nc');
    const errEl=document.getElementById('nuErr');
    errEl.textContent='';
    if(!name){ errEl.textContent='❗ Entre un prénom'; return; }
    if(code.length!==4){ errEl.textContent='❗ Code à 4 chiffres requis'; return; }
    if(REGISTRY[code]){ errEl.textContent='❌ Ce code est déjà pris, choisis-en un autre'; return; }
    const createBtn=document.getElementById('createBtn');
    createBtn.disabled=true; createBtn.textContent='⏳ Création...';
    errEl.textContent='Création de ton espace cloud...';
    const binId=await createUserBin('ts_'+name.replace(/\s/g,'')+'_'+code);
    if(!binId){
      errEl.textContent='❌ Erreur réseau, réessaie'; createBtn.disabled=false; createBtn.textContent='✅ Créer mon profil'; return;
    }
    REGISTRY[code]={name,emoji,binId};
    await saveRegistry();
    createBtn.disabled=false; createBtn.textContent='✅ Créer mon profil';
    renderChips();
    // Migrer les données existantes du bin original si l'utilisateur s'appelle Ewen
    await doLogin(code);
  });

  // Charger le registre et les profils enregistrés
  await loadRegistry();

  // Profil Ewen pré-créé avec les données existantes
  // Le bin original contient déjà les données d'Ewen
  if(!REGISTRY['1234']){
    REGISTRY['1234'] = {name:'Ewen', emoji:'🧭', binId:'69c28010aa77b81da914b2af'};
    await saveRegistry();
  }

  renderChips();

  // Auto-reconnexion si dernière session connue
  const last=localStorage.getItem('ts_lastUser');
  if(last && REGISTRY[last]){
    await doLogin(last);
  } else {
    setTimeout(()=>document.getElementById('cd0')?.focus(), 100);
  }
}

init();
</script>
</body>
</html>
