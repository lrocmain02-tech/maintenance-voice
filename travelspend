function saveTrip(){
  const name=document.getElementById('tName').value.trim();
  if(!name){ toast('❗ Donnez un nom'); return; }
  const data={
    name,
    flag:document.getElementById('tFlag').value.trim()||'✈️',
    budget:parseFloat(document.getElementById('tBudget').value)||0,
    currency:document.getElementById('tCcy').value,
    start:document.getElementById('tStart').value,
    end:document.getElementById('tEnd').value,
    desc:document.getElementById('tDesc').value.trim()
  };
  if(editTripId){
    const i=S.trips.findIndex(t=>t.id===editTripId);
    if(i>=0) S.trips[i]={...S.trips[i],...data};
    save(); scheduleSync(); closeSheet('trip'); renderAll(); updateTopTrip(); toast('✏️ Voyage modifié');
  } else {
    const t={id:uid(),...data,createdAt:new Date().toISOString()};
    S.trips.push(t); if(!S.activeTrip) S.activeTrip=t.id;
    save(); scheduleSync(); closeSheet('trip'); renderAll(); toast('✈️ Voyage "'+t.name+'" créé');
  }
  editTripId=null;
}

function deleteTrip(id){
  if(!confirm('Supprimer ce voyage et ses dépenses ?')) return;
  S.trips=S.trips.filter(t=>t.id!==id); S.expenses=S.expenses.filter(e=>e.tripId!==id);
  if(S.activeTrip===id) S.activeTrip=S.trips[0]?.id||null;
  save(); scheduleSync(); renderAll(); toast('🗑 Voyage supprimé');
}

function setActiveTrip(id){ S.activeTrip=id; save(); updateTopTrip(); showPage('accueil'); toast('✅ Voyage sélectionné'); }

