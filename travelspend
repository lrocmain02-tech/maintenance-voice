// ── UTILS ─────────────────────────────────────────
function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2); }
function fmt(v,ccy){
  if(v===undefined||v===null||isNaN(v)) return '—';
  try{ return new Intl.NumberFormat('fr-FR',{style:'currency',currency:ccy||'EUR',maximumFractionDigits:2}).format(v); }
  catch{ return v.toFixed(2)+' '+(ccy||''); }
}
function fmtD(d){ if(!d) return '—'; return new Date(d+'T12:00:00').toLocaleDateString('fr-FR',{day:'2-digit',month:'short'}); }
function fmtDFull(d){ if(!d) return '—'; return new Date(d+'T12:00:00').toLocaleDateString('fr-FR',{day:'2-digit',month:'long',year:'numeric'}); }
function trip(){ return S.trips.find(t=>t.id===S.activeTrip)||null; }
function tripExps(){ const t=trip(); return t?S.expenses.filter(e=>e.tripId===t.id).sort((a,b)=>b.date.localeCompare(a.date)):[]; }
function toast(msg){
  const el=document.createElement('div'); el.className='toast'; el.textContent=msg;
  document.getElementById('toastWrap').prepend(el);
  setTimeout(()=>{ el.style.opacity='0'; el.style.transition='.25s'; setTimeout(()=>el.remove(),300); },2500);
}

