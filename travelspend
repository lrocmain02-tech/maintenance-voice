// ── RENDER STATS ──────────────────────────────────
function renderStats(){
  const t=trip(); const exps=tripExps();
  if(!t||!exps.length){
    document.getElementById('statsTotal').textContent='—';
    document.getElementById('statsDetails').textContent='Aucune donnée';
    document.getElementById('statsAvg').textContent='—';
    document.getElementById('statsMax').textContent='—';
    document.getElementById('dayBars').innerHTML='';
    document.getElementById('catProgress').innerHTML='';
    if(chartInst){chartInst.destroy();chartInst=null;}
    if(lineChartInst){lineChartInst.destroy();lineChartInst=null;}
    return;
  }
  const spent=exps.reduce((s,e)=>s+(e.amountBase||e.amount),0);
  const days=t.start&&t.end?Math.ceil((new Date(t.end)-new Date(t.start))/86400000):1;
  const maxE=exps.reduce((m,e)=>(e.amountBase||e.amount)>(m.amountBase||m.amount)?e:m,exps[0]);
  document.getElementById('statsTotal').textContent=fmt(spent,t.currency);
  document.getElementById('statsSub').textContent=t.name;
  document.getElementById('statsDetails').textContent=exps.length+' dépenses · '+days+' jours';
  document.getElementById('statsAvg').textContent=fmt(spent/Math.max(days,1),t.currency);
  document.getElementById('statsMax').textContent=fmt(maxE.amountBase||maxE.amount,t.currency);
  // Donut
  const bycat={}; exps.forEach(e=>{bycat[e.category]=(bycat[e.category]||0)+(e.amountBase||e.amount);});
  const sorted=Object.entries(bycat).sort((a,b)=>b[1]-a[1]);
  const ctx=document.getElementById('statsChart').getContext('2d');
  if(chartInst) chartInst.destroy();
  chartInst=new Chart(ctx,{type:'doughnut',data:{labels:sorted.map(([id])=>{const c=CATS.find(x=>x.id===id);return c?c.e+' '+c.l:id;}),datasets:[{data:sorted.map(([,v])=>v),backgroundColor:sorted.map(([id])=>(CAT_CLR[id]||'#7a7f8e')+'cc'),borderColor:sorted.map(([id])=>CAT_CLR[id]||'#7a7f8e'),borderWidth:2,hoverOffset:4}]},options:{responsive:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:(item)=>{const total=item.dataset.data.reduce((s,v)=>s+v,0);return` ${fmt(item.raw,t.currency)} (${(item.raw/total*100).toFixed(0)}%)`;}}}},cutout:'60%'}});
  document.getElementById('statsLegend').innerHTML=sorted.map(([id,val])=>{const c=CATS.find(x=>x.id===id)||{l:id};return`<div class="leg-item"><div class="leg-dot" style="background:${CAT_CLR[id]||'#7a7f8e'}"></div>${c.l} · ${fmt(val,t.currency)}</div>`;}).join('');
  // Barres par jour
  const byDay={}; exps.forEach(e=>{byDay[e.date]=(byDay[e.date]||0)+(e.amountBase||e.amount);});
  const maxDay=Math.max(...Object.values(byDay));
  const sortedDays=Object.keys(byDay).sort((a,b)=>b.localeCompare(a)).slice(0,10);
  const dailyB=t.budget/Math.max(days,1);
  document.getElementById('dayBars').innerHTML=sortedDays.map(d=>{
    const v=byDay[d]; const w=(v/maxDay*100).toFixed(0); const over=v>dailyB;
    return`<div class="day-row"><div class="day-lbl">${fmtD(d)}</div><div class="day-track"><div class="day-fill" style="width:${w}%;background:${over?'var(--red)':'var(--accent)'}">${w>20?`<div class="day-amt">${fmt(v,t.currency)}</div>`:''}</div></div>${w<=20?`<div style="font-size:11px;color:var(--muted);padding-left:6px">${fmt(v,t.currency)}</div>`:''}</div>`;
  }).join('');
  // Graphique ligne
  const allDays=Object.keys(byDay).sort(); let cumul=0;
  const cumulData=allDays.map(d=>{cumul+=byDay[d];return cumul;});
  const budgetLine=allDays.map((_,i)=>parseFloat((dailyB*(i+1)).toFixed(2)));
  const lctx=document.getElementById('lineChart').getContext('2d');
  if(lineChartInst) lineChartInst.destroy();
  lineChartInst=new Chart(lctx,{type:'line',data:{labels:allDays.map(d=>fmtD(d)),datasets:[{label:'Dépensé',data:cumulData,borderColor:'#e8b86d',backgroundColor:'rgba(232,184,109,0.1)',tension:0.3,fill:true,pointRadius:3,pointBackgroundColor:'#e8b86d'},{label:'Budget prévu',data:budgetLine,borderColor:'rgba(92,200,138,0.6)',borderDash:[4,4],tension:0,fill:false,pointRadius:0}]},options:{responsive:true,interaction:{mode:'index',intersect:false},plugins:{legend:{labels:{color:'#7a7f8e',font:{size:11}}},tooltip:{callbacks:{label:(item)=>` ${fmt(item.raw,t.currency)}`}}},scales:{x:{ticks:{color:'#7a7f8e',font:{size:10}},grid:{color:'rgba(128,128,128,0.1)'}},y:{ticks:{color:'#7a7f8e',font:{size:10},callback:(v)=>fmt(v,t.currency)},grid:{color:'rgba(128,128,128,0.1)'}}}}});
  // Progress par catégorie
  document.getElementById('catProgress').innerHTML=sorted.map(([id,val])=>{
    const c=CATS.find(x=>x.id===id)||{l:id,e:'📦'};
    const pct=Math.min(100,(val/spent*100));
    return`<div style="margin-bottom:12px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px">
        <div style="font-size:13px">${c.e} ${c.l}</div>
        <div style="font-size:12px;color:var(--muted)">${fmt(val,t.currency)} · ${pct.toFixed(0)}%</div>
      </div>
      <div style="height:6px;background:var(--bg3);border-radius:99px;overflow:hidden">
        <div style="height:100%;width:${pct}%;background:${CAT_CLR[id]||'#7a7f8e'};border-radius:99px;transition:width 0.5s"></div>
      </div>
    </div>`;
  }).join('');
}

