<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="TravelSpend">
<meta name="theme-color" content="#0e0f11">
<title>TravelSpend</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
:root {
  --bg:#0e0f11; --bg2:#16181c; --bg3:#1e2127; --card:#1a1d22;
  --border:#2a2d35; --border2:#363a45;
  --text:#f0ede8; --muted:#7a7f8e; --muted2:#3e4250;
  --accent:#e8b86d; --accent-soft:rgba(232,184,109,0.13);
  --green:#5cc88a; --red:#e86d6d; --blue:#6d9ee8;
  --r:16px; --r-sm:10px;
  --sat:env(safe-area-inset-top,44px);
  --sab:env(safe-area-inset-bottom,34px);
  --sal:env(safe-area-inset-left,0px);
  --sar:env(safe-area-inset-right,0px);
  --tbh:60px;
}
html.light {
  --bg:#f4f1ec; --bg2:#ffffff; --bg3:#ece8e0; --card:#ffffff;
  --border:#ddd8ce; --border2:#ccc6ba;
  --text:#1c1a16; --muted:#7a7060; --muted2:#bdb8ae;
  --accent:#b8731a; --accent-soft:rgba(184,115,26,0.10);
  --green:#1e8c4a; --red:#c03030; --blue:#1a52b8;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html{height:100%;overflow:hidden;}
body{font-family:'DM Sans',-apple-system,sans-serif;background:var(--bg);color:var(--text);height:100%;overflow:hidden;-webkit-font-smoothing:antialiased;overscroll-behavior:none;}
input,select,textarea,button{font-family:inherit;-webkit-appearance:none;appearance:none;}
select{background-image:none;}
button{border:none;cursor:pointer;}
input[type="number"]{-moz-appearance:textfield;}
input[type="number"]::-webkit-inner-spin-button,input[type="number"]::-webkit-outer-spin-button{-webkit-appearance:none;}

#app{display:flex;flex-direction:column;height:100%;max-width:430px;margin:0 auto;position:relative;overflow:hidden;background:var(--bg);}
.statusbar{height:var(--sat);background:var(--bg2);flex-shrink:0;}

/* TOPBAR */
.topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 16px;height:52px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:relative;z-index:10;}
.logo{font-family:'DM Serif Display',serif;font-size:20px;color:var(--accent);}
.logo span{color:var(--text);}
.trip-pill{display:flex;align-items:center;gap:6px;background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:5px 10px 5px 8px;font-size:13px;color:var(--text);cursor:pointer;max-width:160px;}
.trip-pill:active{opacity:0.7;}
.trip-pill-flag{font-size:15px;}
.trip-pill-name{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.trip-pill-arr{font-size:10px;color:var(--muted);margin-left:2px;}

/* PAGES */
.pages{flex:1;overflow:hidden;position:relative;}
.page{position:absolute;inset:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;overscroll-behavior-y:contain;padding-bottom:calc(var(--tbh) + var(--sab) + 16px);display:none;opacity:0;transition:opacity 0.18s;}
.page.active{display:block;opacity:1;}

/* TABBAR */
.tabbar{height:calc(var(--tbh) + var(--sab));background:var(--bg2);border-top:1px solid var(--border);display:flex;align-items:flex-start;padding-top:8px;padding-bottom:var(--sab);padding-left:var(--sal);padding-right:var(--sar);flex-shrink:0;position:relative;z-index:10;}
.tab-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:4px 0;cursor:pointer;color:var(--muted);transition:color 0.15s;min-height:44px;justify-content:center;}
.tab-btn:active{opacity:0.6;transform:scale(0.95);}
.tab-btn.active{color:var(--accent);}
.tab-btn svg{width:22px;height:22px;}
.tab-lbl{font-size:10px;font-weight:500;}
.fab-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;top:-18px;}
.fab-wrap:active .fab{transform:scale(0.9);box-shadow:0 2px 10px rgba(232,184,109,0.3);}
.fab{width:54px;height:54px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(232,184,109,0.45);color:#1a1000;transition:transform 0.15s,box-shadow 0.15s;}
.fab svg{width:26px;height:26px;}
.fab-lbl{font-size:10px;color:var(--accent);font-weight:500;margin-top:2px;}

/* CARDS */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;}

/* HERO */
.hero{margin:16px;background:linear-gradient(135deg,#1e1a10,#1a1d22);border:1px solid rgba(232,184,109,0.2);border-radius:20px;padding:20px;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;top:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:var(--accent);opacity:0.06;}
.hero-name{font-family:'DM Serif Display',serif;font-size:20px;margin-bottom:2px;}
.hero-dates{font-size:12px;color:var(--muted);margin-bottom:16px;}
.hero-amt{font-family:'DM Serif Display',serif;font-size:40px;color:var(--accent);line-height:1;}
.hero-lbl{font-size:12px;color:var(--muted);margin-bottom:12px;margin-top:4px;}
.prog-track{height:5px;background:var(--bg3);border-radius:99px;overflow:hidden;margin-bottom:8px;}
.prog-fill{height:100%;border-radius:99px;background:var(--accent);transition:width 0.6s cubic-bezier(0.4,0,0.2,1);}
.prog-fill.warn{background:var(--red);}
.prog-fill.ok{background:var(--green);}
.prog-lbls{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);}

/* STATS ROW */
.stat-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:16px 16px 0;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:14px;}
.stat-lbl{font-size:10px;color:var(--muted);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:6px;}
.stat-val{font-family:'DM Serif Display',serif;font-size:22px;line-height:1;}
.stat-val.accent{color:var(--accent);}
.stat-val.green{color:var(--green);}
.stat-val.red{color:var(--red);}
.stat-val.blue{color:var(--blue);}
.stat-sub{font-size:11px;color:var(--muted);margin-top:5px;}

/* SECTION */
.section{padding:16px 16px 0;}
.section-title{font-family:'DM Serif Display',serif;font-size:22px;color:var(--text);margin-bottom:4px;}
.section-sub{font-size:13px;color:var(--muted);margin-bottom:16px;}

/* EXPENSE ITEMS */
.exp-group-lbl{font-size:11px;color:var(--muted);font-weight:600;letter-spacing:0.5px;text-transform:uppercase;padding:14px 16px 6px;display:flex;justify-content:space-between;align-items:center;}
.exp-item{display:flex;align-items:center;gap:12px;padding:12px 16px;cursor:pointer;position:relative;}
.exp-item:active{background:var(--bg3);}
.exp-item+.exp-item{border-top:1px solid var(--border);}
.exp-icon{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.exp-info{flex:1;min-width:0;}
.exp-name{font-size:15px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.exp-meta{font-size:12px;color:var(--muted);margin-top:1px;}
.exp-right{text-align:right;flex-shrink:0;}
.exp-amt{font-family:'DM Serif Display',serif;font-size:17px;}
.exp-conv{font-size:11px;color:var(--muted);margin-top:1px;}
.exp-del{padding:10px 4px 10px 8px;color:var(--red);font-size:22px;cursor:pointer;flex-shrink:0;line-height:1;}

/* TRIP CARDS */
.trip-card{margin:0 16px 12px;background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:16px;cursor:pointer;position:relative;}
.trip-card:active{opacity:0.85;}
.trip-card.atrip{border-color:var(--accent);}
.trip-flag{font-size:32px;margin-bottom:10px;}
.trip-name{font-family:'DM Serif Display',serif;font-size:19px;margin-bottom:2px;}
.trip-dates{font-size:12px;color:var(--muted);margin-bottom:14px;}
.trip-brow{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:10px;}
.trip-spent{font-size:12px;color:var(--muted);}
.trip-total{font-family:'DM Serif Display',serif;font-size:20px;color:var(--accent);}
.trip-badge{position:absolute;top:12px;right:12px;background:var(--accent-soft);color:var(--accent);font-size:10px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;padding:3px 8px;border-radius:99px;border:1px solid rgba(232,184,109,0.2);}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:13px 20px;border-radius:var(--r-sm);font-size:15px;font-weight:500;cursor:pointer;border:none;transition:opacity 0.12s,transform 0.12s;min-height:48px;}
.btn:active{opacity:0.75;transform:scale(0.98);}
.btn-p{background:var(--accent);color:#1a1000;}
.btn-s{background:var(--bg3);color:var(--text);border:1px solid var(--border);}
.btn-d{background:rgba(232,109,109,0.15);color:var(--red);border:1px solid rgba(232,109,109,0.2);}
.btn svg{width:18px;height:18px;}

/* BOTTOM SHEETS */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:200;opacity:0;pointer-events:none;transition:opacity 0.25s;backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px);}
.overlay.open{opacity:1;pointer-events:all;}
.sheet{position:fixed;left:0;right:0;bottom:0;background:var(--bg2);border-radius:24px 24px 0 0;border-top:1px solid var(--border2);z-index:201;transform:translateY(100%);transition:transform 0.32s cubic-bezier(0.32,0.72,0,1);max-height:92vh;display:flex;flex-direction:column;overflow:hidden;padding-bottom:var(--sab);max-width:430px;margin:0 auto;}
.sheet.open{transform:translateY(0);}
.sheet-handle{width:36px;height:4px;background:var(--border2);border-radius:99px;margin:10px auto 0;flex-shrink:0;}
.sheet-hdr{padding:16px 20px 0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.sheet-title{font-family:'DM Serif Display',serif;font-size:20px;}
.sheet-close{width:32px;height:32px;border-radius:50%;background:var(--bg3);border:1px solid var(--border);color:var(--muted);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;}
.sheet-close:active{opacity:0.6;}
.sheet-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:20px;}
.sheet-footer{display:flex;gap:10px;padding:0 20px 8px;flex-shrink:0;}

/* FORMS */
.fg{margin-bottom:16px;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
label{display:block;font-size:12px;color:var(--muted);margin-bottom:7px;letter-spacing:0.3px;}
input,select,textarea{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-sm);color:var(--text);font-size:16px;padding:12px 14px;transition:border-color 0.15s;outline:none;}
input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(232,184,109,0.12);}
select option{background:var(--bg2);}
textarea{resize:none;min-height:80px;}
.amtwrap{position:relative;}
.amtwrap input{font-family:'DM Serif Display',serif;font-size:28px;padding-right:64px;}
.amtccy{position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:13px;color:var(--accent);font-weight:600;}

/* CATEGORY GRID */
.cat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.cat-btn{display:flex;flex-direction:column;align-items:center;gap:4px;padding:10px 6px;border-radius:var(--r-sm);border:1.5px solid var(--border);background:var(--bg3);cursor:pointer;transition:all 0.12s;min-height:60px;}
.cat-btn:active{transform:scale(0.95);}
.cat-btn.sel{border-color:var(--accent);background:var(--accent-soft);}
.cat-e{font-size:22px;}
.cat-l{font-size:10px;color:var(--muted);text-align:center;line-height:1.2;}
.cat-btn.sel .cat-l{color:var(--accent);}

/* CATEGORY FILTER BAR */
.cat-filters{padding:0 16px 12px;display:flex;gap:8px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.cat-filters::-webkit-scrollbar{display:none;}
.cf-btn{background:var(--bg3);border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-size:13px;color:var(--muted);cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all 0.12s;}
.cf-btn:active{transform:scale(0.95);}
.cf-btn.active{background:var(--accent-soft);border-color:var(--accent);color:var(--accent);}

/* CHARTS */
.chart-wrap{padding:0 16px 16px;position:relative;}
canvas{max-height:200px;}
.legend{display:flex;flex-wrap:wrap;gap:8px;padding:8px 16px 16px;}
.leg-item{display:flex;align-items:center;gap:5px;font-size:12px;color:var(--muted);}
.leg-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}

/* DAY BARS */
.day-bars{padding:0 16px 16px;display:flex;flex-direction:column;gap:8px;}
.day-row{display:flex;align-items:center;gap:8px;}
.day-lbl{font-size:11px;color:var(--muted);width:52px;text-align:right;flex-shrink:0;}
.day-track{flex:1;height:22px;background:var(--bg3);border-radius:5px;overflow:hidden;}
.day-fill{height:100%;border-radius:5px;background:var(--accent);display:flex;align-items:center;padding:0 7px;transition:width 0.4s;}
.day-amt{font-size:10px;color:#1a1000;font-weight:600;white-space:nowrap;overflow:hidden;}

/* SETTINGS */
.settings-section{margin:0 16px;background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;}
.settings-row{padding:14px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);min-height:52px;cursor:pointer;}
.settings-row:last-child{border-bottom:none;}
.settings-row:active{background:var(--bg3);}
.sr-lbl{font-size:14px;}
.sr-sub{font-size:12px;color:var(--muted);margin-top:1px;}
.sr-val{font-size:13px;color:var(--muted);text-align:right;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.settings-section-title{font-size:12px;color:var(--muted);letter-spacing:0.5px;text-transform:uppercase;padding:20px 16px 8px;}

/* TOAST */
.toast-wrap{position:fixed;bottom:calc(var(--tbh) + var(--sab) + 12px);left:50%;transform:translateX(-50%);z-index:999;display:flex;flex-direction:column-reverse;align-items:center;gap:8px;pointer-events:none;}
.toast{background:var(--bg2);border:1px solid var(--border2);border-radius:20px;padding:10px 18px;font-size:14px;font-weight:500;color:var(--text);white-space:nowrap;box-shadow:0 8px 32px rgba(0,0,0,0.5);animation:tIn 0.2s ease;}
@keyframes tIn{from{opacity:0;transform:translateY(8px) scale(0.95);}to{opacity:1;transform:translateY(0) scale(1);}}

/* SYNC BADGE */
.sync-badge{position:fixed;top:calc(var(--sat) + 56px);right:12px;background:var(--bg2);border:1px solid var(--border2);border-radius:99px;padding:5px 10px;font-size:11px;color:var(--muted);display:flex;align-items:center;gap:5px;z-index:50;opacity:0;transition:opacity 0.3s;pointer-events:none;}
.sync-badge.show{opacity:1;}
.sync-dot{width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0;}
.sync-dot.spin{background:var(--accent);animation:pulse 0.8s infinite;}
.sync-dot.err{background:var(--red);}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}

/* INSTALL BANNER */
.install-banner{margin:16px 16px 0;background:var(--accent-soft);border:1px solid rgba(232,184,109,0.25);border-radius:var(--r);padding:14px 16px;display:flex;align-items:flex-start;gap:10px;}
.ib-icon{font-size:24px;flex-shrink:0;}
.ib-text{flex:1;}
.ib-title{font-size:14px;font-weight:600;color:var(--accent);margin-bottom:2px;}
.ib-sub{font-size:12px;color:var(--muted);}
.ib-close{color:var(--muted);font-size:20px;cursor:pointer;padding:0 4px;flex-shrink:0;line-height:1;}

/* SPINNER */
.spinner{width:18px;height:18px;border:2px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin 0.6s linear infinite;display:inline-block;}
@keyframes spin{to{transform:rotate(360deg);}}

/* BIG NUM */
.big-num{font-family:'DM Serif Display',serif;font-size:44px;color:var(--accent);line-height:1;}
.divider{height:1px;background:var(--border);margin:16px 0;}

/* ── LOGIN ── */
#loginScreen{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;overflow-y:auto;}
#loginScreen.hidden{display:none;}
.login-logo{font-family:'DM Serif Display',serif;font-size:30px;color:var(--accent);margin-bottom:4px;}
.login-logo span{color:var(--text);}
.login-sub{font-size:13px;color:var(--muted);margin-bottom:32px;text-align:center;}
.login-card{width:100%;max-width:340px;background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px 20px;display:flex;flex-direction:column;gap:14px;}
.login-title{font-family:'DM Serif Display',serif;font-size:20px;text-align:center;}
.code-wrap{display:flex;gap:8px;justify-content:center;}
.code-digit{width:52px;height:62px;background:var(--bg3);border:2px solid var(--border);border-radius:12px;font-family:'DM Serif Display',serif;font-size:30px;color:var(--text);text-align:center;outline:none;transition:border-color .15s;-webkit-appearance:none;caret-color:var(--accent);}
.code-digit:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft);}
.login-err{font-size:12px;color:var(--red);text-align:center;min-height:16px;}
.login-sep{display:flex;align-items:center;gap:8px;color:var(--muted);font-size:11px;}
.login-sep::before,.login-sep::after{content:'';flex:1;height:1px;background:var(--border);}
.chips{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;}
.chip{background:var(--bg3);border:1.5px solid var(--border);border-radius:20px;padding:7px 14px;font-size:13px;color:var(--text);cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .12s;}
.chip:active{transform:scale(.95);}
.chip:hover{border-color:var(--accent);color:var(--accent);}
.new-user-toggle{font-size:13px;color:var(--muted);text-align:center;cursor:pointer;}
.new-user-toggle b{color:var(--accent);}
.new-user-form{display:none;flex-direction:column;gap:12px;}
.new-user-form.open{display:flex;}
/* USER BADGE */
.user-badge{display:flex;align-items:center;gap:5px;font-size:12px;color:var(--muted);cursor:pointer;padding:4px 8px;border-radius:20px;background:var(--bg3);border:1px solid var(--border);}
.user-badge:active{opacity:.7;}
/* THEME BTNs */
.theme-btn{padding:6px 12px;border-radius:8px;font-size:12px;border:1.5px solid var(--border);background:var(--bg3);color:var(--text);cursor:pointer;transition:border-color .15s;}
.theme-btn.active{border-color:var(--accent);color:var(--accent);}
</style>
</head>
<body>

<!-- LOGIN SCREEN (shown until authenticated) -->
<div id="loginScreen">
  <div class="login-logo">✈ Travel<span>Spend</span></div>
  <div class="login-sub">Votre carnet de dépenses de voyage</div>
  <div class="login-card">
    <div class="login-title">Connexion</div>
    <div style="font-size:12px;color:var(--muted);text-align:center">Code à 4 chiffres</div>
    <div class="code-wrap">
      <input class="code-digit" id="cd0" type="tel" maxlength="1" autocomplete="off">
      <input class="code-digit" id="cd1" type="tel" maxlength="1" autocomplete="off">
      <input class="code-digit" id="cd2" type="tel" maxlength="1" autocomplete="off">
      <input class="code-digit" id="cd3" type="tel" maxlength="1" autocomplete="off">
    </div>
    <div class="login-err" id="loginErr"></div>
    <button class="btn btn-p" id="loginBtn" style="width:100%">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
      Entrer
    </button>
    <div class="login-sep">ou choisissez un profil</div>
    <div class="chips" id="savedChips"><span style="font-size:12px;color:var(--muted2)">Chargement...</span></div>
