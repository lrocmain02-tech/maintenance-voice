// ── CONFIG ──────────────────────────────────────────
const API_KEY = '$2a$10$UN1wNut8OI2K/uZt0vSda.Htt7YAnPvT5upP64T4N7rbhe7N8jrtS';
const JSONBIN = 'https://api.jsonbin.io/v3';
const CCYS = ['EUR','USD','GBP','CHF','JPY','CAD','AUD','CNY','KRW','THB','VND','IDR','MXN','BRL','INR','TRY','SEK','NOK','DKK','SGD','HKD','NZD','ZAR','AED','MAD','CZK','PLN','HUF','MYR'];
const CATS = [
  {id:'food',e:'🍜',l:'Repas'},{id:'trans',e:'🚂',l:'Transport'},
  {id:'hotel',e:'🏨',l:'Hébergement'},{id:'activ',e:'🎭',l:'Activités'},
  {id:'shop',e:'🛍️',l:'Shopping'},{id:'health',e:'💊',l:'Santé'},
  {id:'bar',e:'🍺',l:'Bar'},{id:'other',e:'📦',l:'Autre'},
];
const CAT_CLR = {food:'#e86d6d',trans:'#6d9ee8',hotel:'#5cc8c8',activ:'#a06de8',shop:'#e8896d',health:'#5cc88a',bar:'#e8b86d',other:'#7a7f8e'};

// ── STATE ───────────────────────────────────────────
const FIXED_BIN_ID = '69c28010aa77b81da914b2af';
let S = {trips:[],expenses:[],activeTrip:null,binId:FIXED_BIN_ID,apiKey:API_KEY,baseCcy:'EUR',rates:{},ratesTs:0};
let editExpId = null, chartInst = null, syncTimer = null, activeCatFilter = '';

// ── STORAGE ─────────────────────────────────────────
function save(){
  S.binId = FIXED_BIN_ID; // toujours forcer le bon bin ID
  localStorage.setItem('ts3',JSON.stringify(S));
}
function load(){
  try{const d=localStorage.getItem('ts3');if(d)S={...S,...JSON.parse(d)};}catch(e){}
  S.binId = FIXED_BIN_ID; // forcer même après chargement local
  S.apiKey = API_KEY;
}

// ── CLOUD ───────────────────────────────────────────
async function cloudSync(){
  if(!S.apiKey)return;
  syncUI('spin','Sync...');
  try{
    const body=JSON.stringify({trips:S.trips,expenses:S.expenses,binId:FIXED_BIN_ID,baseCcy:S.baseCcy});
    const res=await fetch(`${JSONBIN}/b/${FIXED_BIN_ID}`,{
      method:'PUT',
      headers:{
        'Content-Type':'application/json',
        'X-Master-Key':S.apiKey,
        'X-Bin-Private':'false'
      },
      body
    });
    if(res&&res.ok){
      syncUI('ok','Synchronisé');
      document.getElementById('lastSyncTime').textContent='Sync : '+new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
    } else {
      const txt = await res.text().catch(()=>'');
      console.error('Sync error',res.status, txt);
      syncUI('err','Erreur '+res.status);
    }
  }catch(e){
    console.error('Sync exception',e);
    syncUI('err','Hors ligne');
  }
}

async function cloudLoad(){
  try{
    syncUI('spin','Chargement cloud...');
    const res=await fetch(`${JSONBIN}/b/${FIXED_BIN_ID}/latest`,{
      headers:{
        'X-Master-Key':API_KEY,
        'X-Bin-Private':'false'
      }
    });
    if(res.ok){
      const d=(await res.json()).record;
      if(d&&(d.trips?.length||d.expenses?.length)){
        // Fusionner intelligemment : garder les données les plus récentes
        const localHasData = S.trips.length > 0 || S.expenses.length > 0;
        if(localHasData){
          // Fusionner en évitant les doublons par ID
          const mergedTrips = [...S.trips];
          (d.trips||[]).forEach(ct=>{if(!mergedTrips.find(lt=>lt.id===ct.id))mergedTrips.push(ct);});
          const mergedExp = [...S.expenses];
          (d.expenses||[]).forEach(ce=>{if(!mergedExp.find(le=>le.id===ce.id))mergedExp.push(ce);});
          S.trips=mergedTrips;S.expenses=mergedExp;
        } else {
          S.trips=d.trips||[];S.expenses=d.expenses||[];
        }
        if(d.baseCcy)S.baseCcy=d.baseCcy;
        S.binId=FIXED_BIN_ID;
        save();renderAll();
        syncUI('ok','Cloud chargé ✓');
        toast('☁️ '+S.trips.length+' voyage(s) · '+S.expenses.length+' dépense(s) chargés');
      } else {
        syncUI('ok','Bin vide');
        // Bin vide sur le cloud : pousser les données locales si on en a
        if(S.trips.length>0)cloudSync();
      }
    } else {
      console.error('CloudLoad error',res.status);
      syncUI('err','Erreur cloud '+res.status);
      toast('⚠️ Cloud inaccessible ('+res.status+') — données locales utilisées');
    }
  }catch(e){
    console.error('CloudLoad exception',e);
    syncUI('err','Hors ligne');
    toast('📱 Mode hors ligne — données locales');
  }
}

function scheduleSync(){clearTimeout(syncTimer);syncTimer=setTimeout(cloudSync,1500);}

function syncUI(state,txt){
  const dot=document.getElementById('syncDot'),badge=document.getElementById('syncBadge'),t=document.getElementById('syncTxt');
  dot.className='sync-dot'+(state==='spin'?' spin':state==='err'?' err':'');
  t.textContent=txt;badge.classList.add('show');
  clearTimeout(badge._t);badge._t=setTimeout(()=>badge.classList.remove('show'),2500);
}

// ── RATES ───────────────────────────────────────────
async function getRate(from,to){
  if(from===to)return 1;
  const k=`${from}_${to}`;
  if(S.rates[k]&&Date.now()-S.ratesTs<3600000)return S.rates[k];
  try{
    const r=await fetch(`https://api.exchangerate-api.com/v4/latest/${from}`);
    if(r.ok){const d=await r.json();CCYS.forEach(c=>S.rates[`${from}_${c}`]=d.rates[c]||1);S.ratesTs=Date.now();save();return S.rates[k]||1;}
  }catch(e){}
  return S.rates[k]||1;
}

