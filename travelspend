function setupCodeInputs(prefix, onComplete){
  for(let i=0;i<4;i++){
    const el = document.getElementById(prefix+i);
    if(!el) continue;
    el.addEventListener('input', ()=>{
      el.value = el.value.replace(/\D/g,'').slice(-1);
      if(el.value && i<3) document.getElementById(prefix+(i+1)).focus();
      if(i===3 && el.value) onComplete && onComplete();
    });
    el.addEventListener('keydown', e=>{
      if(e.key==='Backspace' && !el.value && i>0) document.getElementById(prefix+(i-1)).focus();
    });
    el.addEventListener('paste', e=>{
      const txt = (e.clipboardData||window.clipboardData).getData('text').replace(/\D/g,'').slice(0,4);
      for(let j=0;j<txt.length;j++){
        const d=document.getElementById(prefix+j); if(d) d.value=txt[j];
      }
      document.getElementById(prefix+Math.min(txt.length-1,3))?.focus();
      e.preventDefault();
    });
  }
}

function getCode(prefix){
  return [0,1,2,3].map(i=>document.getElementById(prefix+i)?.value||'').join('');
}

function renderChips(){
  const el = document.getElementById('savedChips');
  if(!el) return;
  const entries = Object.entries(REGISTRY);
  if(!entries.length){ el.innerHTML='<span style="font-size:12px;color:var(--muted2)">Aucun profil enregistré</span>'; return; }
  el.innerHTML = entries.map(([code,u])=>
    `<div class="chip" data-code="${code}">
      <span>${u.emoji||'👤'}</span>
      <span>${u.name||'?'}</span>
    </div>`
  ).join('');
  el.querySelectorAll('.chip').forEach(chip=>{
    chip.addEventListener('click', ()=> doLogin(chip.dataset.code));
  });
}

async function doLogin(code){
  const u = REGISTRY[code];
  if(!u){ setLoginErr('❌ Code inconnu'); return; }
  currentUser = {code, ...u};
  // Load local state for this user
  S = {trips:[],expenses:[],activeTrip:null,baseCcy:'EUR',rates:{},ratesTs:0};
  try{ const d=localStorage.getItem('ts_'+code); if(d) S={...S,...JSON.parse(d)}; }catch(e){}
  localStorage.setItem('ts_lastUser', code);
  // Update UI
  document.getElementById('topUserEmoji').textContent = u.emoji||'👤';
  document.getElementById('topUserName').textContent  = u.name||'—';
  document.getElementById('loginScreen').classList.add('hidden');
  populateSelects(); updateTopTrip(); showPage('accueil'); showInstallBanner();
  renderSettings();
  await cloudLoad();
}

function setLoginErr(msg){ const el=document.getElementById('loginErr'); if(el) el.textContent=msg; }
function setNuErr(msg){ const el=document.getElementById('nuErr'); if(el) el.textContent=msg; }

function logout(){
  if(!confirm('Se déconnecter de '+(currentUser?.name||'ce compte')+' ?')) return;
  currentUser = null;
  S = {trips:[],expenses:[],activeTrip:null,baseCcy:'EUR',rates:{},ratesTs:0};
