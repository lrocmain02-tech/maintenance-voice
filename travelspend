// CLOUD SYNC (bin propre à l'utilisateur)
// ══════════════════════════════════════════════════
async function cloudSync(){
  if(!currentUser?.binId) return;
  syncUI('spin','Sync...');
  try{
    const r = await fetch(`${JSONBIN}/b/${currentUser.binId}`,{
      method:'PUT',
      headers:{'Content-Type':'application/json','X-Master-Key':API_KEY,'X-Bin-Private':'false'},
      body: JSON.stringify({trips:S.trips,expenses:S.expenses,baseCcy:S.baseCcy})
    });
    if(r.ok){
      syncUI('ok','Synchronisé');
      const el=document.getElementById('lastSyncTime');
      if(el) el.textContent='Sync : '+new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
    } else { syncUI('err','Erreur '+r.status); }
  }catch(e){ syncUI('err','Hors ligne'); }
}

async function cloudLoad(){
  if(!currentUser?.binId) return;
  syncUI('spin','Chargement...');
  try{
    const r = await fetch(`${JSONBIN}/b/${currentUser.binId}/latest`,
      {headers:{'X-Master-Key':API_KEY,'X-Bin-Private':'false'}});
    if(r.ok){
      const d = (await r.json()).record;
      if(d && (d.trips?.length||d.expenses?.length)){
        // Merge intelligente : pas de doublons par ID
        const mt=[...S.trips];
        (d.trips||[]).forEach(t=>{ if(!mt.find(x=>x.id===t.id)) mt.push(t); });
        const me=[...S.expenses];
        (d.expenses||[]).forEach(e=>{ if(!me.find(x=>x.id===e.id)) me.push(e); });
        S.trips=mt; S.expenses=me;
        if(d.baseCcy) S.baseCcy=d.baseCcy;
        save(); renderAll();
        syncUI('ok','Chargé ✓');
        toast('☁️ '+S.trips.length+' voyage(s) · '+S.expenses.length+' dépense(s)');
      } else {
        syncUI('ok','Prêt');
        if(S.trips.length>0) cloudSync();
      }
    } else { syncUI('err','Erreur '+r.status); toast('⚠️ Cloud indisponible — données locales'); }
  }catch(e){ syncUI('err','Hors ligne'); toast('📱 Mode hors ligne'); }
}

function scheduleSync(){ clearTimeout(syncTimer); syncTimer=setTimeout(cloudSync,1500); }

function syncUI(state,txt){
  const dot=document.getElementById('syncDot'), badge=document.getElementById('syncBadge'), t=document.getElementById('syncTxt');
  if(!dot||!badge||!t) return;
  dot.className='sync-dot'+(state==='spin'?' spin':state==='err'?' err':'');
  t.textContent=txt; badge.classList.add('show');
  clearTimeout(badge._t); badge._t=setTimeout(()=>badge.classList.remove('show'),2500);
}

// ── RATES ─────────────────────────────────────────
async function getRate(from,to){
  if(from===to) return 1;
  const k=`${from}_${to}`;
  if(S.rates[k]&&Date.now()-S.ratesTs<3600000) return S.rates[k];
  try{
    const r=await fetch(`https://api.exchangerate-api.com/v4/latest/${from}`);
    if(r.ok){const d=await r.json();CCYS.forEach(c=>S.rates[`${from}_${c}`]=d.rates[c]||1);S.ratesTs=Date.now();save();return S.rates[k]||1;}
  }catch(e){}
  return S.rates[k]||1;
}

