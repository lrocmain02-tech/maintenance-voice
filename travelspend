function renderExpenses(){
  const t=trip(); let exps=tripExps();
  if(activeCatFilter) exps=exps.filter(e=>e.category===activeCatFilter);
  const spent=exps.reduce((s,e)=>s+(e.amountBase||e.amount),0);
  document.getElementById('depSub').textContent=exps.length+' dépense'+(exps.length!==1?'s':'')+(t?' · '+fmt(spent,t.currency):'');
  const usedCats=[...new Set(tripExps().map(e=>e.category))];
  document.getElementById('catFilters').innerHTML=
    `<div class="cf-btn${!activeCatFilter?' active':''}" onclick="filterCat(this,'')">Tout</div>`+
    usedCats.map(cid=>{const c=CATS.find(x=>x.id===cid)||{e:'📦',l:cid};return`<div class="cf-btn${activeCatFilter===cid?' active':''}" onclick="filterCat(this,'${cid}')">${c.e} ${c.l}</div>`;}).join('');
  if(!exps.length){
    document.getElementById('expList').innerHTML=`<div style="display:flex;flex-direction:column;align-items:center;padding:48px 24px;gap:8px"><div style="font-size:40px;opacity:0.4">🧾</div><div style="font-size:14px;color:var(--muted)">Aucune dépense</div></div>`;
    return;
  }
  const groups={}; exps.forEach(e=>{ if(!groups[e.date]) groups[e.date]=[]; groups[e.date].push(e); });
