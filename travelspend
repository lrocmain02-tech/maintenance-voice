  Object.keys(groups).sort((a,b)=>b.localeCompare(a)).forEach(date=>{
    const dayTotal=groups[date].reduce((s,e)=>s+(e.amountBase||e.amount),0);
    html+=`<div class="exp-group-lbl"><span>${fmtDFull(date)}</span><span>${fmt(dayTotal,t?.currency)}</span></div>`;
    html+=`<div class="card" style="margin:0 16px 8px">${groups[date].map(e=>expHTML(e,t)).join('')}</div>`;
  });
  document.getElementById('expList').innerHTML=html;
}

function expHTML(e,t){
  const cat=CATS.find(c=>c.id===e.category)||CATS[7];
  const sameCcy=!t||e.currency===t.currency;
